# Copy to ".env" next to manage.py. Never commit .env.

# --- Production / Docker (optional locally) ---
# DJANGO_SECRET_KEY=long-random-string
# DEBUG=0
# ALLOWED_HOSTS=yourapp.railway.app,www.example.com
# Optional: full public URL (defaults to https://RAILWAY_PUBLIC_DOMAIN or built-in Railway hostname)
# PUBLIC_APP_URL=https://bank-production-f72a.up.railway.app
# DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME
# DATABASE_SSL_REQUIRE=1
# Comma-separated; append to default localhost CORS/CSRF lists
# DEPLOYMENT_CORS_ORIGINS=https://your-frontend.example.com
# DEPLOYMENT_CSRF_TRUSTED_ORIGINS=https://your-frontend.example.com,https://yourapp.railway.app

# TWILIO — https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Optional override (generally keep empty): if set, OTP always goes to this E.164 number.
# Default behavior: user jis number pe signup kare, OTP usi par jaye.
OTP_FIXED_PHONE_E164=

# BREVO — https://app.brevo.com/settings/keys/smtp
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
# Verified Gmail (or domain) for From — required if login is *@smtp-brevo.com
BREVO_SENDER_EMAIL=
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=AlyBank <verified@email.com>
BANK_NAME_EMAIL=AlyBank

# Optional overrides
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Vite (frontend/.env)
# VITE_DJANGO_URL=http://127.0.0.1:8000
