# Copy to ".env" next to manage.py. Twilio: https://www.twilio.com/console

# Always AC... from dashboard (not SK...)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional: use API Key instead of Auth Token for HTTP Basic auth (SK... + secret from Console)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Optional testing: set to force one number; leave empty = use whatever user types on register form
OTP_FIXED_PHONE_E164=

# Email OTP — real Gmail/inbox: set SMTP (e.g. Gmail app password). If unset, DEBUG prints mail to terminal.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=app-password
# DEFAULT_FROM_EMAIL=AlyBank <you@gmail.com>
