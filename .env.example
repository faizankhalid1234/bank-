# Copy to ".env" next to manage.py. Never commit .env.

# TWILIO — https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Trial/dev: force OTP to one E.164 number; empty = use form phone (production)
OTP_FIXED_PHONE_E164=

# BREVO — https://app.brevo.com/settings/keys/smtp
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
# Verified Gmail (or domain) for From — required if login is *@smtp-brevo.com
BREVO_SENDER_EMAIL=
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=AlyBank <verified@email.com>
BANK_NAME_EMAIL=AlyBank

# Optional overrides
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Vite (frontend/.env)
# VITE_DJANGO_URL=http://127.0.0.1:8000
