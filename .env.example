# Copy to ".env" next to manage.py. Twilio: https://www.twilio.com/console

# Always AC... from dashboard (not SK...)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional: use API Key instead of Auth Token for HTTP Basic auth (SK... + secret from Console)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Optional testing: set to force one number; leave empty = use whatever user types on register form
OTP_FIXED_PHONE_E164=
